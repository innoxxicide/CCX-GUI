<idea-plugin>
    <id>com.github.ccx-gui</id>
    <name>CCX GUI (Claude or Codex)</name>
    <vendor>innoxxicide</vendor>

    <!-- Resource bundle for i18n -->
    <resource-bundle>messages.ClaudeCodeGuiBundle</resource-bundle>

    <description><![CDATA[
        <p><strong>In Claude we trust</strong></p>
        <p>A fork of the original <a href="https://github.com/zhukunpenglinyutong/jetbrains-cc-gui">CC GUI</a> plugin, forked at v0.4.7.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <!-- Optional: Terminal support for terminal output monitoring -->
    <depends optional="true" config-file="terminal-features.xml">org.jetbrains.plugins.terminal</depends>
    <!-- Optional: Java support for enhanced context collection in Java/Kotlin IDEs -->
    <depends optional="true" config-file="java-features.xml">com.intellij.java</depends>
    <!-- Optional: Python support for enhanced context collection in PyCharm/IDEA with Python plugin -->
    <depends optional="true" config-file="python-features.xml">com.intellij.modules.python</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- CCX GUI tool window (includes history feature) -->
        <toolWindow id="CCXG"
                    anchor="right"
                    factoryClass="com.github.ccxgui.ui.toolwindow.ClaudeSDKToolWindow"
                    icon="/icons/ccx-gui-icon.svg"
                    canCloseContents="true"/>

        <!-- Pre-extract AI Bridge on project open to avoid EDT freeze -->
        <postStartupActivity implementation="com.github.ccxgui.startup.BridgePreloader"/>

        <!-- Cleanup old ai-bridge cache when plugin version changes -->
        <postStartupActivity implementation="com.github.ccxgui.startup.PluginUpdateListener"/>

        <!-- Monitor Run/Debug Service Output -->
        <postStartupActivity implementation="com.github.ccxgui.service.RunConfigMonitorService"/>

        <!-- StatusBar widget for task notification -->
        <statusBarWidgetFactory id="CCXGUIStatusBarWidget"
                                implementation="com.github.ccxgui.notifications.ClaudeStatusBarWidget$Factory"/>

        <!-- Notification group for DevTools and other balloon notifications -->
        <notificationGroup id="CCX GUI Notifications" displayType="BALLOON"/>
    </extensions>

    <actions>
        <!-- Action to send selected code to CCX GUI -->
        <action id="CCXGUI.SendSelectionToTerminalAction"
                class="com.github.ccxgui.action.editor.SendSelectionToTerminalAction"
                icon="/icons/ccx-gui-icon.svg">
            <!-- Add to editor context menu (displayed at the top) -->
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt K"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt K"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta alt K"/>
        </action>

        <!-- Copy AI Reference Action -->
        <action id="CCXGUI.CopySelectionReferenceAction"
                class="com.github.ccxgui.action.editor.CopySelectionReferenceAction"
                icon="/icons/ccx-gui-icon.svg">
            <add-to-group group-id="EditorPopupMenu"
                           anchor="after"
                           relative-to-action="CCXGUI.SendSelectionToTerminalAction"/>
        </action>

        <!-- Quick Fix with Claude Action -->
        <action id="CCXGUI.QuickFixWithClaudeAction"
                class="com.github.ccxgui.action.editor.QuickFixWithClaudeAction"
                icon="/icons/ccx-gui-icon.svg">
            <add-to-group group-id="EditorPopupMenu"
                           anchor="after"
                           relative-to-action="CCXGUI.SendSelectionToTerminalAction"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift Q"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift Q"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta shift Q"/>
        </action>

        <!-- Create New Tab Action (can be invoked via Find Action or programmatically) -->
        <action id="CCXGUI.CreateNewTabAction"
                class="com.github.ccxgui.action.tab.CreateNewTabAction"
                icon="AllIcons.General.Add"/>

        <!-- Rename Tab Action -->
        <action id="CCXGUI.RenameTabAction"
                class="com.github.ccxgui.action.tab.RenameTabAction"
                icon="AllIcons.Actions.Edit"/>

        <!-- Detach Tab Action -->
        <action id="CCXGUI.DetachTabAction"
                class="com.github.ccxgui.action.tab.DetachTabAction"
                icon="AllIcons.Actions.MoveToWindow"/>

        <!-- Save As Template Action -->
        <action id="CCXGUI.SaveAsTemplateAction"
                class="com.github.ccxgui.action.SaveAsTemplateAction"
                icon="AllIcons.Actions.Menu_saveall"/>

        <!-- Create From Template Action -->
        <action id="CCXGUI.CreateFromTemplateAction"
                class="com.github.ccxgui.action.CreateFromTemplateAction"
                icon="AllIcons.Actions.AddMulticaret"/>

        <!-- Open DevTools Action for JCEF debugging -->
        <action id="CCXGUI.OpenDevToolsAction"
                class="com.github.ccxgui.action.dev.OpenDevToolsAction"
                icon="AllIcons.Xml.Browsers.Chromium"/>

        <!-- Action to send file path from the file tree to the input box -->
        <action id="CCXGUI.SendFilePathToInputAction"
                class="com.github.ccxgui.action.editor.SendFilePathToInputAction"
                icon="/icons/ccx-gui-icon.svg">
            <!-- Add to project file tree and editor tab context menus -->
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="first"/>
        </action>

        <!-- Action to send the selected console text to CCX GUI -->
        <action id="CCXGUI.SendConsoleSelectionToInputAction"
                class="com.github.ccxgui.action.console.SendConsoleSelectionToInputAction"
                icon="/icons/ccx-gui-icon.svg">
            <add-to-group group-id="ConsoleView.PopupMenu" anchor="last"/>
        </action>

        <!-- Generate Commit Message with AI Action -->
        <action id="CCXGUI.GenerateCommitMessageAction"
                class="com.github.ccxgui.action.vcs.GenerateCommitMessageAction"
                icon="/icons/logo-16.png">
            <!-- Add to VCS Commit toolbar -->
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>

        <!-- Chat tool window clipboard actions (scoped to CCG tool window) -->
        <action id="CCXGUI.ChatCopyAction"
                class="com.github.ccxgui.action.ChatCopyAction"
                text="Copy (Chat Window)"
                description="Copy selected text in Claude chat window">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl C"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta C"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta C"/>
        </action>
        <action id="CCXGUI.ChatCutAction"
                class="com.github.ccxgui.action.ChatCutAction"
                text="Cut (Chat Window)"
                description="Cut selected text in Claude chat window">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl X"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta X"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta X"/>
        </action>
        <action id="CCXGUI.ChatPasteAction"
                class="com.github.ccxgui.action.ChatPasteAction"
                text="Paste (Chat Window)"
                description="Paste clipboard text in Claude chat window">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl V"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta V"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="meta V"/>
        </action>

        <!-- Chat tool window send action (no default shortcut; dynamically managed by SendShortcutSync) -->
        <action id="CCXGUI.ChatSendAction"
                class="com.github.ccxgui.action.ChatSendAction"
                text="Send Message (Chat Window)"
                description="Send message in Claude chat window"/>

        <!-- Chat tool window newline action (Shift+Enter always newline; Ctrl+Enter dynamically managed by SendShortcutSync) -->
        <action id="CCXGUI.ChatNewlineAction"
                class="com.github.ccxgui.action.ChatNewlineAction"
                text="Insert Newline (Chat Window)"
                description="Insert newline in Claude chat window input">
            <keyboard-shortcut keymap="$default" first-keystroke="shift ENTER"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="shift ENTER"/>
            <keyboard-shortcut keymap="macOS" first-keystroke="shift ENTER"/>
        </action>

        <!--
          Hide CCX GUI Panel. A standalone action with NO default keyboard shortcut: users may bind one
          in Settings | Keymap to hide the tool window while focus is in the IDE (e.g. the editor).
          NOTE: The Shift+Esc shortcut that hides the panel while focus is INSIDE the webview is
          implemented separately in WebviewInitializer via a JS keydown listener
          (document.addEventListener -> JBCefJSQuery -> ToolWindow.hide()); it does NOT go through this
          action. Shift+Esc is intentionally not registered here to avoid clashing with the IDE's
          built-in HideActiveWindow shortcut.
        -->
        <action id="CCXGUI.HidePanelAction"
                class="com.github.ccxgui.action.HidePanelAction"
                text="Hide CCX GUI Panel"
                description="Hide the CCX GUI tool window panel"/>
    </actions>
</idea-plugin>
